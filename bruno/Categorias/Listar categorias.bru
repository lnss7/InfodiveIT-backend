meta {
  name: Listar categorias
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/categorias
  body: none
  auth: none
}

vars:pre-request {
  baseUrl: http://localhost:8080/api/v1
}

docs {
  GET público. Lista as soluções ativas (consumidas como "categorias"
  pelo frontend) ordenadas por ordem. nome ← titulo, descricaoCompleta ← overview.
}
