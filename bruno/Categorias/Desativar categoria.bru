meta {
  name: Desativar categoria
  type: http
  seq: 5
}

delete {
  url: {{baseUrl}}/categorias/{{categoriaId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

vars:pre-request {
  baseUrl: http://localhost:8080/api/v1
  categoriaId: 00000000-0000-0000-0000-000000000000
}

docs {
  PROTEGIDO (JWT). Soft delete (ativo = false). Retorna 204 No Content.
}
