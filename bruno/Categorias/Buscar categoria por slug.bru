meta {
  name: Buscar categoria por slug
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/categorias/{{categoriaSlug}}
  body: none
  auth: none
}

vars:pre-request {
  baseUrl: http://localhost:8080/api/v1
  categoriaSlug: seguranca
}

docs {
  GET público. 200 com a categoria ou 404 no formato padrão caso o slug não exista.
}
